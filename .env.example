# Local development (optional — defaults work with npm start)
PORT=3000
NODE_ENV=development

# Comma-separated allowed CORS origins (production / Render / Koyeb)
CORS_ORIGIN=http://localhost:3000,https://ravo-44c4c.web.app,https://ravo-44c4c.firebaseapp.com

# API-only mode (backend separate from Firebase Hosting frontend)
API_ONLY=true

# ── Storage backend ──────────────────────────────────────────────
# json      = local db.json file (default, good for local dev)
# firestore = Firebase Firestore (persistent, stateless hosting)
STORAGE_BACKEND=json

# Firebase Firestore (required when STORAGE_BACKEND=firestore)
FIREBASE_PROJECT_ID=ravo-44c4c

# Paste the FULL service account JSON on ONE line (from Firebase Console →
# Project Settings → Service Accounts → Generate new private key)
# On Render/Koyeb: add as a secret env var (not committed to git).
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"ravo-44c4c",...}

# Alternative: path to service account file (local dev only)
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/firebase-service-account.json

# Optional Firestore document location (defaults shown)
# FIRESTORE_COLLECTION=p2p
# FIRESTORE_STATE_DOC=state

# ── JSON file storage only (STORAGE_BACKEND=json) ─────────────────
# Stateless free hosting: data in RAM only (resets on restart)
# STORAGE_MODE=memory

# Persistent data directory (when host provides a writable volume)
# DATA_DIR=/var/data

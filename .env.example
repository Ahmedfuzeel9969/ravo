# Local development (optional — defaults work with npm start)
PORT=3000
NODE_ENV=development

# Comma-separated allowed CORS origins (production / Render)
CORS_ORIGIN=http://localhost:3000,https://ravo-44c4c.web.app,https://ravo-44c4c.firebaseapp.com

# API-only mode on Render (no static frontend from this server)
API_ONLY=true

# Persistent data directory (Render disk mount path when using paid plan)
# DATA_DIR=/var/data
